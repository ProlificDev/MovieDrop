# MoviePulse Backend Environment Variables
# Copy this file to .env and fill in the missing secrets

# FastAPI Server Ingress Security
# Set this to a JSON-formatted list of origins allowed to connect
# e.g., ["http://localhost:3000", "https://your-netlify-app.netlify.app"]
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Supabase Database Secrets
# Get these from your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-secret..."

# The Movie Database (TMDB) API Auth Key
# Get this from your TMDB Profile Settings -> API Section
TMDB_API_KEY="your_tmdb_api_key_here"

# Resend Transactional Email Secrets
# Get this from your Resend Dashboard
RESEND_API_KEY="re_123456789..."

# Celery Task Broker & State Store
# Set this to your Upstash Redis Connection String
REDIS_URL="rediss://default:your-redis-password@your-upstash-instance.upstash.io:6379"

# Web Push VAPID Secrets
# Pre-populated with the secure P-256 keys generated in Phase 1 setup
VAPID_PUBLIC_KEY="BB2zElxtnFRzgEDnFBrVW-jzINWc4bZcd69F5azs7nlUXadF1VdPIKJ3Cj2auaKI7FooewRPhRLDl6pK03UA1NA"
VAPID_PRIVATE_KEY="yo0rO4joqMDe8eMQwoLkZpMDuUpy0FKbJaX5qPkphFs"

# Web Push Support Contact Address
VAPID_CLAIM_EMAIL="mailto:your-email@example.com"
